[*.vb]

# CA1305: Especificar IFormatProvider
dotnet_diagnostic.CA1305.severity = none

# CA1802: Usar literales cuando resulte apropiado
dotnet_diagnostic.CA1802.severity = silent

# CA1031: No capture tipos de excepción generales.
dotnet_diagnostic.CA1031.severity = none

# CA1308: Normalizar las cadenas en mayúsculas
dotnet_diagnostic.CA1308.severity = none
